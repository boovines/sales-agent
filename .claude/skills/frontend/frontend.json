  "vibe": {
    "summary": "Dark, editorial sophistication with a dash of technical precision. Think high-end product magazine meets developer documentation—refined serif headlines, monospace details, muted sage green accents against deep blacks. Generous whitespace, understated elegance, no decoration without purpose. Like a beautifully typeset technical journal. Serious but not sterile, confident but not aggressive.",
    
    "keywords": [
      "editorial",
      "sophisticated",
      "dark",
      "technical",
      "refined",
      "minimal",
      "serif headlines",
      "monospace accents",
      "sage green",
      "spacious",
      "confident"
    ],
    
    "references": [
      "ARK Business",
      "The New York Times dark mode",
      "Linear's sophistication",
      "Notion's clarity",
      "Technical documentation aesthetics"
    ],
    
    "characteristics": [
      "Large serif headlines (editorial feel)",
      "Muted, desaturated color palette",
      "Generous line heights and letter spacing",
      "Monospace for UI elements and labels",
      "Sage/olive green as primary accent",
      "Deep blacks, not pure black",
      "Subtle borders, never harsh",
      "Typography does the heavy lifting",
      "Whitespace as a design element"
    ]
  },
  
