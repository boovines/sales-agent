  "designPrinciples": {
    "typography": [
      "Serif headlines (Playfair Display) for editorial sophistication",
      "Sans-serif body (Inter) for readability",
      "Monospace labels (IBM Plex Mono) for UI elements - uppercase, wide letter spacing",
      "Generous line heights (1.7+ for body text)",
      "Tight tracking on large headlines",
      "Wide tracking on small labels",
      "Use italic Playfair for emphasis within headlines"
    ],
    "color": [
      "Muted sage/olive green (#9CA896) as primary accent",
      "Never pure black - use #0A0A0A to #181818 range",
      "Desaturated, sophisticated palette - no bright colors",
      "Text is slightly off-white (#E8E8E8), not pure white",
      "Secondary text is muted (#A0A0A0)",
      "Borders are subtle (#242424)",
      "Status colors (error, success) are also desaturated"
    ],
    "spacing": [
      "Generous whitespace - don't be afraid of empty space",
      "Large padding on sections (6rem, 8rem)",
      "Comfortable line heights",
      "Breathing room around all elements"
    ],
    "interactions": [
      "Smooth, refined transitions (250ms)",
      "Subtle hover states - no dramatic changes",
      "Border color shifts on focus",
      "Slight background lightening on hover",
      "No shadows on hover (shadows are for elevation only)"
    ],
    "layout": [
      "Max width containers (1280px)",
      "Centered content",
      "Left-aligned text (editorial style)",
      "Single column for readability",
      "Cards/sections have clear separation"
    ],
    "architecture": [
      "This frontend is a placeholder - build everything to be rip-and-replaceable with Figma assets later",
      "Separate presentation components from logic containers - logic in hooks/containers, visuals in leaf components",
      "Never embed business logic, data fetching, or state management inside styled/visual components",
      "Use a single theme/token file as the source of truth for all colors, fonts, spacing - never hardcode values in components",
      "Keep component APIs (props interfaces) stable and generic - the visual internals can change but the contract should not",
      "Prefer composition over inheritance - small, single-purpose visual components that are easy to swap individually",
      "All images, icons, and illustrations should be imported from a central assets directory, not inline SVGs or hardcoded paths",
      "Use semantic class names or style abstractions (e.g. 'surface', 'elevated') not visual ones (e.g. 'dark-gray-box')"
    ]
  },
  
  "implementationNotes": {
    "figmaReplaceability": [
      "IMPORTANT: This entire visual layer is a functional placeholder meant to be replaced with Figma designs later",
      "Structure every page as: page container (layout + data) -> section components (composition) -> visual primitives (replaceable)",
      "Create a ui/ directory for all visual primitives (Button, Card, Input, Label, Badge, etc.) - these are the swap targets",
      "All visual primitives must accept className/style overrides so Figma exports can override any default styling",
      "Keep component files small and focused - one visual concern per file makes replacement surgical, not sweeping",
      "Use a theme provider or CSS variables layer so the entire color/font/spacing system can be swapped by changing one file",
      "All assets (icons, illustrations, images) go in a central assets/ directory with named exports - never scatter or inline them",
      "Do NOT build complex custom CSS animations or hand-tuned layouts that would be painful to recreate - keep it simple and standard",
      "When building layouts, use standard CSS grid/flexbox patterns that any Figma-to-code tool can reproduce",
      "Document component prop interfaces clearly - when Figma components replace these, the props contract is what stays stable"
    ],
    "fonts": [
      "Load Playfair Display with italic variant for emphasis words",
      "Use IBM Plex Mono as Berkeley Mono alternative",
      "Inter for all body copy and UI text",
      "Never mix fonts within a component - be consistent"
    ],
    "typography": [
      "H1: 6rem Playfair, normal weight, tight line height",
      "Use <em> tags with Playfair italic for words like 'code' in headlines",
      "Labels: 0.75rem IBM Plex Mono, uppercase, 0.1em letter spacing",
      "Body: 1rem Inter, 1.7 line height, #A0A0A0 color"
    ],
    "buttons": [
      "Primary: sage green background, dark text, uppercase monospace",
      "Secondary: transparent with border, same typography",
      "Never use shadows on buttons",
      "Generous padding (2rem horizontal)"
    ],
    "forms": [
      "Subtle borders (#242424)",
      "Focus state: sage green border",
      "Small border radius (4px)",
      "Labels above inputs, monospace uppercase"
    ]
  }
