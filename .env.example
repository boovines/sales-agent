BRAVE_API_KEY=  # Brave Search API key. Get from https://api.search.brave.com/ (free tier: 2000 queries/month) https://brave.com/search/api/
GROK_API_KEY=  # Grok API key. Get from https://console.x.ai/ (used for X/Twitter context research only, no DM sending)
GITHUB_TOKEN=  # GitHub personal access token. Needs no special scopes — public repo read access only. Create at https://github.com/settings/tokens
ANTHROPIC_API_KEY=  # Anthropic Claude API key. Used by Research and Qualification agents (not this agent)
FIRECRAWL_API_KEY=  # Firecrawl API key. Used by Research agent (not this agent)
PERPLEXITY_API_KEY=  # Perplexity API key. Used by Research agent (not this agent)
COMPOSIO_API_KEY=  # Composio API key. Used by Drafting agent (not this agent)
DAILY_DISCOVERY_CAP=20  # Maximum new companies added to queue per day across all runs
DISCOVERY_INTERVAL_HOURS=12  # How often the scheduled discovery run fires (hours)
DB_PATH=adela.db  # Path to SQLite database file. Created automatically on first run
DASHBOARD_TOKEN=dev-token  # Bearer token for dashboard API authentication

GMAIL_SENDER_ADDRESS=
DAILY_EMAIL_CAP=20
DAILY_GITHUB_CAP=5
DAILY_LINKEDIN_CAP=10

